{
  "name": "modern-shelter/backend",
  "description": "PHP Backend API for Alsace Hideaways booking system",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "ext-pdo": "*"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S localhost:4000 -t public",
    "lint": "phpcs --standard=PSR12 src/"
  }
}
