# Database Configuration
# Use 127.0.0.1 rather than "localhost" — some MySQL clients treat
# "localhost" as a signal to connect via a Unix socket file instead of
# TCP, which fails with SQLSTATE[HY000] [2002] on hosts where that
# socket path doesn't match what PHP expects.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=shelter
DB_USER=root
DB_PASSWORD=

# API Configuration
FRONTEND_URL=http://localhost:5173
API_PORT=4000
ENVIRONMENT=development

# Admin
ADMIN_SECRET=your_admin_secret_key

# Swikly (payment provider) — get these from your Swikly dashboard under
# Applications and integrations > Developer. Use api.sandbox.swikly.com/v1
# for testing, api.v2.swikly.com/v1 for production.
SWIKLY_BASE_URL=https://api.v2.swikly.com/v1
SWIKLY_API_KEY=
SWIKLY_ACCOUNT_ID=
SWIKLY_SECRET=

# Email notifications (Gmail SMTP via PHPMailer) — new-booking alerts to the admin.
# SMTP_PASSWORD must be a Gmail App Password (Google Account > Security >
# 2-Step Verification > App passwords), not the regular account password —
# Gmail blocks plain-password SMTP login.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ADMIN_NOTIFICATION_EMAIL=
