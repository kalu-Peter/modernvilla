# Database Configuration
# Use 127.0.0.1 rather than "localhost" — some MySQL clients treat
# "localhost" as a signal to connect via a Unix socket file instead of
# TCP, which fails with SQLSTATE[HY000] [2002] on hosts where that
# socket path doesn't match what PHP expects.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=shelter
DB_USER=root
DB_PASSWORD=

# API Configuration
FRONTEND_URL=http://localhost:5173
API_PORT=4000
ENVIRONMENT=development

# Admin
ADMIN_SECRET=your_admin_secret_key
